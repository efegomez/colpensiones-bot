# ============================================================
#  COLPENSIONES + WHATSAPP AUTOMÁTICO — Variables de Entorno
#  Copia este archivo como .env y rellena tus valores reales.
#  NUNCA subas el archivo .env a Git o compartas sus valores.
# ============================================================

# --- Credenciales Colpensiones ---
USER=tu_usuario_colpensiones
PASSWORD=tu_contraseña_colpensiones

# --- Número de WhatsApp destino (formato internacional) ---
# Ejemplo: +573001234567
PHONE_NUMBER=+57XXXXXXXXXX

# --- Twilio WhatsApp API ---
# Consíguelos en: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Número Twilio WhatsApp (sandbox o número aprobado) ---
# Sandbox: whatsapp:+14155238886
# Producción: whatsapp:+tu_numero_twilio
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- (Opcional) Cédula para búsqueda de trámite ---
CEDULA=XXXXXXXXXX
